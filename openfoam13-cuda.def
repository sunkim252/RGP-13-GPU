Bootstrap: docker
From: nvidia/cuda:12.4.1-devel-ubuntu22.04

%labels
    Author      sunkim
    Project     RGP-13
    Description OpenFOAM 13 + CUDA 12.4 development image

%arguments
    OPENFOAM_VERSION=13
    NPROC=8

%post
    export DEBIAN_FRONTEND=noninteractive

    # ── 1. System dependencies ──────────────────────────────────────────
    apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        cmake \
        git \
        flex \
        bison \
        zlib1g-dev \
        libboost-system-dev \
        libboost-thread-dev \
        libfftw3-dev \
        libscotch-dev \
        libptscotch-dev \
        libreadline-dev \
        libgmp-dev \
        libmpfr-dev \
        libmpc-dev \
        libcgal-dev \
        gnuplot \
        wget \
        ca-certificates \
        openmpi-bin \
        libopenmpi-dev \
    && rm -rf /var/lib/apt/lists/*

    # ── 2. Clone OpenFOAM 13 ────────────────────────────────────────────
    cd /opt
    git clone --depth 1 https://github.com/OpenFOAM/OpenFOAM-13.git
    git clone --depth 1 https://github.com/OpenFOAM/ThirdParty-13.git

    # ── 3. Compile OpenFOAM ─────────────────────────────────────────────
    export FOAM_INST_DIR=/opt
    /bin/bash -c "\
        source /opt/OpenFOAM-13/etc/bashrc && \
        cd /opt/ThirdParty-13 && ./Allwmake 2>&1 | tail -3 && \
        cd /opt/OpenFOAM-13   && ./Allwmake -j ${NPROC} 2>&1 | tail -5"

    # ── 4. Install CUDA wmake rules ─────────────────────────────────────
    #    .cu 컴파일 규칙을 wmake에 등록한다.
    #    이 규칙 파일은 컨테이너 내장이므로 RGP-13 소스에 의존하지 않는다.

    RULES_DIR=/opt/OpenFOAM-13/wmake/rules/linux64Gcc

    cat > ${RULES_DIR}/cuda <<'CUDA_RULES'
# ── wmake CUDA compilation rules ──
# Invoked by wmake's DEFINE_TRANSFORM macro for .cu suffix

SUFFIXES += .cu

CUDA_ARCH   = -gencode arch=compute_89,code=sm_89
NVCC        = nvcc
NVCC_FLAGS  = -std=c++14 -O3 --use_fast_math \
              -Xcompiler -fPIC -Xcompiler -Wall \
              $(CUDA_ARCH) \
              -DLIB_NAME=$(notdir $(LIB).$(SO)) \
              -D$(WM_ARCH) -DWM_ARCH_OPTION=$(WM_ARCH_OPTION) \
              -DWM_$(WM_PRECISION_OPTION) -DWM_LABEL_SIZE=$(WM_LABEL_SIZE)

cutoo       = $(WM_SCHEDULER) $(NVCC) $(NVCC_FLAGS) \
              $(LIB_HEADER_DIRS) -c $< -o $@
CUDA_RULES

    # general에 cuda rules를 include
    echo 'include $(DEFAULT_RULES)/cuda' >> ${RULES_DIR}/general

    # ── 5. Verify ───────────────────────────────────────────────────────
    /bin/bash -c "\
        source /opt/OpenFOAM-13/etc/bashrc && \
        echo '=== OpenFOAM ===' && foamVersion && \
        echo '=== CUDA ===' && nvcc --version | tail -1 && \
        echo '=== wmake CUDA ===' && cat \${WM_DIR}/rules/linux64Gcc/cuda"

%environment
    export FOAM_INST_DIR=/opt
    export CUDA_HOME=/usr/local/cuda
    export PATH=${CUDA_HOME}/bin:${PATH}
    export LD_LIBRARY_PATH=${CUDA_HOME}/lib64:${LD_LIBRARY_PATH}

    # RGP-13 라이브러리 경로 (호스트에서 bind-mount)
    if [ -n "${LIB_RGP13_SRC}" ]; then
        export LD_LIBRARY_PATH=${FOAM_USER_LIBDIR}:${LD_LIBRARY_PATH}
    fi

%runscript
    exec /bin/bash --rcfile <(echo "source /opt/OpenFOAM-13/etc/bashrc") -i

%test
    /bin/bash -c "\
        source /opt/OpenFOAM-13/etc/bashrc && \
        simpleFoam -help 2>/dev/null | tail -3 && \
        nvcc --version | tail -1" \
    && echo "RGP-13 base image: OK"
