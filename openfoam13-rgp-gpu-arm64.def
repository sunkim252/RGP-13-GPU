Bootstrap: docker
From: nvidia/cuda:12.4.1-devel-ubuntu22.04

# в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# openfoam13-rgp-gpu-arm64.def вҖ” GH200(Grace-Hopper, aarch64)мҡ© RGP-13-GPU
#
# x86 def(openfoam13-rgp-gpu.def)мқҳ aarch64 нҢҗ. **GH200 л…ёл“ңм—җм„ң л№Ңл“ң**н•ҙм•ј
# н•ңлӢӨ(apptainerк°Җ нҳёмҠӨнҠё м•„м№ҳмқҳ docker мқҙлҜём§ҖлҘј pull вҖ” nvidia/cuda нғңк·ёлҠ”
# multi-archлқј к°ҷмқҖ нғңк·ёлЎң arm64 л Ҳмқҙм–ҙлҘј л°ӣлҠ”лӢӨ).
#
#   apptainer build openfoam13-rgp-gpu-arm64.sif openfoam13-rgp-gpu-arm64.def
#
# x86 нҢҗкіјмқҳ м°Ёмқҙ:
#  - OpenFOAM/ThirdPartyлҘј %files ліөмӮ¬ лҢҖмӢ  мҶҢмҠӨ нҒҙлЎ  вҶ’ aarch64 л„ӨмқҙнӢ°лёҢ л№Ңл“ң
#    (WM_ARCH=linuxArm64; лЎңм»¬ x86 л№Ңл“ң нҠёлҰ¬лҠ” мһ¬мӮ¬мҡ© л¶Ҳк°Җ)
#  - CUDA_ARCH: sm_90(H100) + compute_90 PTX(Blackwellкёү JIT нҸҙл°ұ)
#  - MPI кІҪлЎң: Make/optionsк°Җ $(shell uname -m)мңјлЎң м•„м№ҳ-мӨ‘лҰҪ (мҲҳм • мҷ„лЈҢ)
#  - AmgX: MPI л№Ңл“ң н•„мҲҳ(л¶„мӮ° API) вҖ” cmake лЎңк·ёмқҳ "MPI build:TRUE" кІҖмҰқ
#
# GH200 лёҢл§Ғм—… мІҙнҒ¬лҰ¬мҠӨнҠё (мІ« мӢӨн–үм—җм„ң нҷ•мқё):
#  1. thermoGPU ARMED л°°л„Ҳ: "coherent HW: yes" + "unified-native" вҖ”
#     rgpGpuInitмқҙ PageableMemoryAccessUsesHostPageTablesлЎң мһҗлҸҷ к°җм§Җ
#  2. RGP_GPU_UNIFIED=0мңјлЎң к°•м ң copy мӢӨн–үкіј н•„л“ң л№„нҠё лҢҖмЎ°(м •н•© нҷ•мқё)
#  3. л©ҖнӢ° мҠҲнҚјм№©: лһӯнҒ¬вҶ’GPU л§Өн•‘(myProcNo % nDev), gpuPEqnSolver
#     pcg/amgx л‘ҳ лӢӨ лі‘л ¬ м§Җмӣҗ
# в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

%labels
    Author sunkim
    Project RGP-13-GPU
    Description OpenFOAM-13 + RGP-13 realFluid + CUDA (GH200 aarch64, coherent-ready)

%files
    RGP-13-realFluid /opt/OpenFOAM/RGP-13-realFluid

%environment
    export FOAM_INST_DIR=/opt/OpenFOAM
    export CUDA_HOME=/usr/local/cuda
    export PATH=${CUDA_HOME}/bin:${PATH}
    export AMGX_DIR=/opt/OpenFOAM/ThirdParty-13/platforms/linuxArm64Gcc/amgx-2.4.0
    export LD_LIBRARY_PATH=${CUDA_HOME}/lib64:${AMGX_DIR}/lib:${LD_LIBRARY_PATH}
    export LIB_RGP13_SRC=/opt/OpenFOAM/RGP-13-realFluid/src
    . /opt/OpenFOAM/OpenFOAM-13/etc/bashrc || true

%post
    export DEBIAN_FRONTEND=noninteractive

    apt-get update && apt-get install -y --no-install-recommends \
        build-essential ca-certificates cmake git wget flex bison \
        zlib1g-dev libboost-system-dev libboost-thread-dev \
        libopenmpi-dev openmpi-bin gnuplot libreadline-dev \
        libncurses-dev libxt-dev rsync python3
    rm -rf /var/lib/apt/lists/*

    # в”Җв”Җв”Җ OpenFOAM-13 + ThirdParty-13 (aarch64 л„ӨмқҙнӢ°лёҢ л№Ңл“ң) в”Җв”Җв”Җ
    mkdir -p /opt/OpenFOAM && cd /opt/OpenFOAM
    if [ ! -d OpenFOAM-13 ]; then
        git clone --depth 1 https://github.com/OpenFOAM/OpenFOAM-13.git
        git clone --depth 1 https://github.com/OpenFOAM/ThirdParty-13.git
    fi
    # вҡ пёҸ лЎңм»¬ AMR core-mod(adce153)лҘј м“°л Өл©ҙ мң„ нҒҙлЎ  лҢҖмӢ  мҲҳм • нҠёлҰ¬лҘј
    #    rsyncлЎң к°Җм ёмҳ¬ кІғ (GH200м—җм„ң x86 %files ліөмӮ¬лҠ” л¶Ҳк°Җ вҖ” мҶҢмҠӨлҠ”
    #    м•„м№ҳ л¬ҙкҙҖмқҙлҜҖлЎң rsync/gitмқҙ м •лӢө)
    set +e; . /opt/OpenFOAM/OpenFOAM-13/etc/bashrc; set -e
    cd /opt/OpenFOAM/OpenFOAM-13 && ./Allwmake -j $(nproc) 2>&1 | tail -5

    # в”Җв”Җв”Җ wmake CUDA лЈ° (linuxArm64Gcc): H100 sm_90 + PTX нҸҙл°ұ в”Җв”Җв”Җ
    # x86 defмҷҖ лҸҷмқј кө¬мЎ°(кІҖмҰқлҗЁ): rules/<arch>/cuda нҢҢмқј + generalм—җ include.
    # мЈјмқҳ: OF-13мқҳ ARM лЈ° л””л үн„°лҰ¬ мқҙлҰ„мқҖ linuxArm64Gcc.
    RULES_DIR=/opt/OpenFOAM/OpenFOAM-13/wmake/rules/linuxArm64Gcc
    [ -d "$RULES_DIR" ] || { echo "ARM64 rules dir missing: $RULES_DIR"; exit 1; }

    cat > $RULES_DIR/cuda <<'CUDA_RULES'
# в”Җв”Җ wmake CUDA compilation rules (aarch64 / GH200) в”Җв”Җ
SUFFIXES += .cu

CUDA_ARCH   = -gencode arch=compute_90,code=sm_90 -gencode arch=compute_90,code=compute_90
NVCC        = nvcc
# -fmad=false: FMA м¶•м•Ҫ кёҲм§Җ -- CPU(g++ л№„-FMA мҪ”л“ңм  )мҷҖмқҳ ULP м •н•©.
# --use_fast_math кёҲм§Җ(м •н•© кІҖмҰқ мӢ лў°м„ұ). x86 лЈ°кіј н”Ңлһҳк·ё лҸҷмқј мң м§Җ.
NVCC_FLAGS  = -std=c++14 -O3 -fmad=false \
              -Xcompiler -fPIC -Xcompiler -Wall \
              $(CUDA_ARCH) \
              -DLIB_NAME=$(notdir $(LIB).$(SO)) \
              -D$(WM_ARCH) -DWM_ARCH_OPTION=$(WM_ARCH_OPTION) \
              -DWM_$(WM_PRECISION_OPTION) -DWM_LABEL_SIZE=$(WM_LABEL_SIZE)

cutoo       = $(WM_SCHEDULER) $(NVCC) $(NVCC_FLAGS) \
              $(LIB_HEADER_DIRS) -c $< -o $@
CUDA_RULES

    grep -q 'rules)/cuda' $RULES_DIR/general 2>/dev/null || \
        echo 'include $(DEFAULT_RULES)/cuda' >> $RULES_DIR/general

    # в”Җв”Җв”Җ RGP-13 realFluid + GPU мҠӨнғқ (x86 defмҷҖ лҸҷмқј мҲңм„ң) в”Җв”Җв”Җ
    set +e; . /opt/OpenFOAM/OpenFOAM-13/etc/bashrc; set -e
    export FOAM_USER_LIBBIN=$FOAM_LIBBIN
    export LIB_RGP13_SRC=/opt/OpenFOAM/RGP-13-realFluid/src
    export CUDA_HOME=/usr/local/cuda
    cd /opt/OpenFOAM/RGP-13-realFluid
    ( cd src/thermoGPU && wmake libso ) 2>&1 | tail -3
    ( cd src && ./Allwmake ) 2>&1 | tail -3
    ( cd applications/modules/fgmFluid && wmake libso ) 2>&1 | tail -3
    ( cd applications/modules/gpuMulticomponentFluid && wmake libso ) \
        2>&1 | tail -3
    ( cd src/gpuChemistry && wmake libso ) 2>&1 | tail -3

    # в”Җв”Җв”Җ AmgX (sm_90 + MPI н•„мҲҳ вҖ” л¶„мӮ° API) в”Җв”Җв”Җ
    export AMGX_DIR=/opt/OpenFOAM/ThirdParty-13/platforms/linuxArm64Gcc/amgx-2.4.0
    cd /opt/OpenFOAM/ThirdParty-13
    git clone --recursive --depth 1 -b v2.4.0 \
        https://github.com/NVIDIA/AMGX.git amgx-src
    mkdir -p amgx-src/build && cd amgx-src/build
    cmake .. -DCUDA_ARCH="90" -DCMAKE_INSTALL_PREFIX=$AMGX_DIR \
        -DMPI_C_COMPILER=mpicc -DMPI_CXX_COMPILER=mpicxx | tee cmake.log
    grep -q "This is a MPI build:TRUE" cmake.log \
        || { echo "AmgX: MPI NOT FOUND"; exit 1; }
    make -j$(nproc) amgxsh && make install
    cd /opt/OpenFOAM/ThirdParty-13 && rm -rf amgx-src
    ( cd /opt/OpenFOAM/RGP-13-realFluid/src/amgxFoam && wmake libso ) \
        2>&1 | tail -3

    # мӮ°м¶ңл¬ј кІҖмҰқ
    ls -lh $FOAM_LIBBIN/libRGP13realFluid.so $FOAM_LIBBIN/libfgmFluid.so \
        $FOAM_LIBBIN/libgpuMulticomponentFluid.so \
        $FOAM_LIBBIN/librgpThermoGPU.so $FOAM_LIBBIN/libRGP13gpuChemistry.so \
        $FOAM_LIBBIN/libRGP13amgx.so

%runscript
    exec /bin/bash "$@"
