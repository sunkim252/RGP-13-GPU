Bootstrap: docker
From: nvidia/cuda:12.4.1-devel-ubuntu22.04

# ─────────────────────────────────────────────────────────────────────────────
# openfoam13-rgp-gpu.def — RGP-13-GPU 개발 컨테이너
#
# openfoam13-rgp.def(CPU, ubuntu:22.04 베이스)와 구 openfoam13-cuda.def
# (nvidia/cuda 베이스 + wmake CUDA 룰)를 병합한 이미지.
#  - 로컬 OpenFOAM-13 트리(AMR core-mod adce153 반영본)를 그대로 복사해 빌드
#  - RGP-13 real-fluid 플러그인 install.sh 설치 (CPU 이미지와 동일 경로)
#  - wmake CUDA 룰(sm_89, RTX 4060) 등록 → src/thermoGPU를 build/Allwmake로 빌드
#  - PETSc + AmgX 선형솔버 오프로드 스택은 옵션 섹션(주석) — 착수 시 활성화
#
# 빌드 (RGP-13-GPU 디렉토리에서):
#   apptainer build openfoam13-rgp-gpu.sif openfoam13-rgp-gpu.def
# 실행:
#   apptainer exec --nv openfoam13-rgp-gpu.sif bash
# ─────────────────────────────────────────────────────────────────────────────

%labels
    Author sunkim
    Project RGP-13-GPU
    Description OpenFOAM-13 + RGP-13 Real Fluid Models + CUDA 12.4 (thermoGPU, AmgX-ready)

%files
    OpenFOAM-13      /opt/OpenFOAM/OpenFOAM-13
    ThirdParty-13    /opt/OpenFOAM/ThirdParty-13
    RGP-13-realFluid /opt/OpenFOAM/RGP-13-realFluid

%environment
    export FOAM_INST_DIR=/opt/OpenFOAM
    export CUDA_HOME=/usr/local/cuda
    export PATH=${CUDA_HOME}/bin:${PATH}
    export AMGX_DIR=/opt/OpenFOAM/ThirdParty-13/platforms/linux64Gcc/amgx-2.4.0
    export LD_LIBRARY_PATH=${CUDA_HOME}/lib64:${AMGX_DIR}/lib:${LD_LIBRARY_PATH}
    export LIB_RGP13_SRC=/opt/OpenFOAM/RGP-13-realFluid/src
    . /opt/OpenFOAM/OpenFOAM-13/etc/bashrc || true

%post
    export DEBIAN_FRONTEND=noninteractive

    apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        ca-certificates \
        cmake \
        flex \
        bison \
        git \
        libfl-dev \
        libopenmpi-dev \
        openmpi-bin \
        libscotch-dev \
        libptscotch-dev \
        libfftw3-dev \
        libboost-system-dev \
        libboost-thread-dev \
        libreadline-dev \
        zlib1g-dev \
        gnuplot \
        wget \
        && rm -rf /var/lib/apt/lists/*

    # ─── %post는 /bin/sh(dash)로 실행되므로 bash로 전환 ───
    /bin/bash << 'EOFBASH'
    set -e -o pipefail

    export FOAM_INST_DIR=/opt/OpenFOAM
    export CUDA_HOME=/usr/local/cuda
    export PATH=$CUDA_HOME/bin:$PATH

    # bashrc 내부의 unalias 등이 비0 종료를 반환해 set -e를 죽이므로 가드
    set +e
    . /opt/OpenFOAM/OpenFOAM-13/etc/bashrc
    set -e
    [ -n "$WM_PROJECT_DIR" ] || { echo "ERROR: OpenFOAM bashrc sourcing failed"; exit 1; }

    echo "WM_PROJECT_DIR = $WM_PROJECT_DIR"
    echo "FOAM_LIBBIN    = $FOAM_LIBBIN"
    nvcc --version | tail -1

    # ─── wmake CUDA 룰 등록 (.cu → nvcc; Ada sm_89 + Hopper sm_90
    #     — GH200/H100 대비 fat binary + PTX 전방호환) ───
    RULES_DIR=$WM_PROJECT_DIR/wmake/rules/linux64Gcc

    cat > $RULES_DIR/cuda <<'CUDA_RULES'
# ── wmake CUDA compilation rules ──
SUFFIXES += .cu

CUDA_ARCH   = -gencode arch=compute_75,code=sm_75 -gencode arch=compute_89,code=sm_89 -gencode arch=compute_90,code=sm_90 -gencode arch=compute_90,code=compute_90
NVCC        = nvcc
# -fmad=false: FMA 축약 금지 -- CPU(g++ 비-FMA 코드젠)와의 ULP 정합을 위해.
# --use_fast_math는 정합 검증(Test-rgpThermoGPU) 신뢰성을 위해 제외.
NVCC_FLAGS  = -std=c++14 -O3 -fmad=false \
              -Xcompiler -fPIC -Xcompiler -Wall \
              $(CUDA_ARCH) \
              -DLIB_NAME=$(notdir $(LIB).$(SO)) \
              -D$(WM_ARCH) -DWM_ARCH_OPTION=$(WM_ARCH_OPTION) \
              -DWM_$(WM_PRECISION_OPTION) -DWM_LABEL_SIZE=$(WM_LABEL_SIZE)

cutoo       = $(WM_SCHEDULER) $(NVCC) $(NVCC_FLAGS) \
              $(LIB_HEADER_DIRS) -c $< -o $@
CUDA_RULES

    grep -q 'rules)/cuda' $RULES_DIR/general 2>/dev/null || \
        echo 'include $(DEFAULT_RULES)/cuda' >> $RULES_DIR/general

    # ─── ThirdParty 컴파일 (scotch) ───
    cd $WM_THIRD_PARTY_DIR
    ./Allwmake -j$(nproc) 2>&1 | tail -5

    # ─── OpenFOAM-13 컴파일 ───
    cd $WM_PROJECT_DIR
    ./Allwmake -j$(nproc) 2>&1 | tail -20

    # ─── RGP-13 플러그인 빌드 (표준 Allwmake 경로) ───
    # install.sh(레거시 트리패치)는 현행 템플릿 소스와 불일치(redefinition) — 사용 금지.
    # 라이브러리는 사용자 홈이 아닌 이미지 내 플랫폼 libbin에 굽는다.
    export FOAM_USER_LIBBIN=$FOAM_LIBBIN
    export FOAM_USER_APPBIN=$FOAM_APPBIN
    # wmake 병렬화: 인자(-jN)는 'wmake libso' 뒤에 오면 디렉토리로 오인되므로 env로
    export WM_NCOMPPROCS=$(nproc)
    # fgmFluid Make/options가 참조하는 realFluid 소스 경로 (사용자 컨벤션)
    export LIB_RGP13_SRC=/opt/OpenFOAM/RGP-13-realFluid/src

    cd /opt/OpenFOAM/RGP-13-realFluid
    ./Allwmake 2>&1 | tail -10

    # thermoGPU CUDA 커널 — fgmFluid가 -lrgpThermoGPU를 링크하므로 먼저
    # (빌드 머신에 GPU가 없어도 컴파일은 가능; 실행만 --nv 필요)
    ( cd src/thermoGPU && wmake libso ) 2>&1 | tail -2

    # fgmFluid 솔버 모듈 + 테이블 유틸리티
    ( cd applications/modules/fgmFluid && wmake libso ) 2>&1 | tail -5
    # 일반 연소(finite-rate/EDC) GPU 모듈
    ( cd applications/modules/gpuMulticomponentFluid && wmake libso ) 2>&1 | tail -5
    ( cd applications/utilities/fgmTabulateRealGasCoeffs && wmake ) 2>&1 | tail -3
    ( cd applications/utilities/fgmTabulateLewis && wmake ) 2>&1 | tail -3

    # GPU finite-rate 화학 (chemistryType { solver gpu; })
    ( cd src/gpuChemistry && wmake libso ) 2>&1 | tail -3

    # ─── thermoGPU 검증 유틸 ───
    ( cd applications/utilities/Test-rgpThermoGPU && wmake ) 2>&1 | tail -3

    # 산출물 검증 — 없으면 이미지 빌드 자체를 실패시킨다
    ls -lh $FOAM_LIBBIN/libRGP13realFluid.so $FOAM_LIBBIN/libfgmFluid.so \
           $FOAM_LIBBIN/libgpuMulticomponentFluid.so \
           $FOAM_LIBBIN/librgpThermoGPU.so \
           $FOAM_APPBIN/fgmTabulateRealGasCoeffs $FOAM_APPBIN/fgmTabulateLewis \
           $FOAM_APPBIN/Test-rgpThermoGPU

    # ─── Dynamic compilation 템플릿 업데이트 ───
    TEMPLATE="$WM_PROJECT_DIR/etc/codeTemplates/dynamicCode/fluidMulticomponentThermo"

    grep -q 'SRKchungTakaMixture' "$TEMPLATE" || \
        sed -i '/coefficientWilkeMulticomponentMixture/a\    SRKchungTakaMixture' "$TEMPLATE"

    grep -q '    chung$' "$TEMPLATE" || \
        sed -i '/    Andrade/a\    chung' "$TEMPLATE"

    grep -q '    SRKGas$' "$TEMPLATE" || \
        sed -i '/    rPolynomial/a\    SRKGas' "$TEMPLATE"

    grep -q '    rfSpecie$' "$TEMPLATE" || \
        sed -i '/^    specie$/a\    rfSpecie' "$TEMPLATE"


    # ─── AmgX 스택 (libRGP13amgx — fvSolution 'solver amgx' +
    #     fgmProperties 'gpuPEqnSolver amgx') ────────────────────────────
    # 로컬 ThirdParty에 빌드된 amgx-2.4.0이 %files로 함께 복사된다.
    # 없으면(새 호스트) 소스에서 sm_89+sm_90으로 빌드.
    export AMGX_DIR=/opt/OpenFOAM/ThirdParty-13/platforms/linux64Gcc/amgx-2.4.0
    if [ ! -f $AMGX_DIR/lib/libamgxsh.so ]; then
        cd /opt/OpenFOAM/ThirdParty-13
        git clone --recursive --depth 1 -b v2.4.0 \
            https://github.com/NVIDIA/AMGX.git amgx-src
        mkdir -p amgx-src/build && cd amgx-src/build
        cmake .. -DCUDA_ARCH="89;90" -DCMAKE_INSTALL_PREFIX=$AMGX_DIR
        make -j$(nproc) && make install
        cd /opt/OpenFOAM/ThirdParty-13 && rm -rf amgx-src
    fi
    ( cd /opt/OpenFOAM/RGP-13-realFluid/src/amgxFoam && wmake libso ) \
        2>&1 | tail -3
    ls -lh $FOAM_LIBBIN/libRGP13amgx.so

    # ─── (옵션) PETSc — petsc4Foam Foundation-13 포팅 필요, 미착수 ───────
    # cd /opt/OpenFOAM/ThirdParty-13
    # git clone --depth 1 -b v3.21.4 https://gitlab.com/petsc/petsc.git petsc-3.21.4
    # cd petsc-3.21.4
    # ./configure --with-cuda --with-cudac=nvcc --with-precision=double \
    #     --with-mpi-dir=/usr/lib/x86_64-linux-gnu/openmpi \
    #     --prefix=/opt/OpenFOAM/ThirdParty-13/platforms/linux64Gcc/petsc-3.21.4
    # make -j$(nproc) && make install
    # ─────────────────────────────────────────────────────────────────────

    echo "=== Build complete ==="
EOFBASH

%runscript
    . /opt/OpenFOAM/OpenFOAM-13/etc/bashrc
    exec "$@"

%test
    /bin/bash -c "\
        . /opt/OpenFOAM/OpenFOAM-13/etc/bashrc && \
        foamRun -help 2>/dev/null | tail -3 && \
        nvcc --version | tail -1" \
    && echo "RGP-13-GPU image: OK"

%help
    OpenFOAM-13 + RGP-13 Real Fluid Models + CUDA 12.4 (GPU 개발 이미지)

    Usage:
      apptainer build openfoam13-rgp-gpu.sif openfoam13-rgp-gpu.def
      apptainer exec --nv openfoam13-rgp-gpu.sif bash      # GPU 사용 시 --nv 필수
      apptainer exec --nv openfoam13-rgp-gpu.sif foamRun
