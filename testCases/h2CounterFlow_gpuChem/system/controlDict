FoamFile
{
    format          ascii;
    class           dictionary;
    location        "system";
    object          controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solver          gpuMulticomponentFluid;

startFrom       startTime;

startTime       0;

stopAt          endTime;

endTime         4e-4;

deltaT          1e-06;

writeControl    adjustableRunTime;

writeInterval   0.0002;

purgeWrite      0;

writeFormat     ascii;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable true;

adjustTimeStep  yes;

maxCo           0.4;

libs            ( "libRGP13gpuChemistry.so" );


