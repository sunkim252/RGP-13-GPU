#!/bin/bash
#------------------------------------------------------------------------------
# RGP-13 thermoGPU build script
#
# librgpThermoGPU.so (Foam-free CUDA 커널) + Test-rgpThermoGPU 검증 유틸을
# 빌드한다. 메인 플러그인(libRGP13realFluid.so)은 상위 ./Allwmake로 먼저
# 빌드돼 있어야 한다.
#
# Usage (inside container):
#   source /opt/OpenFOAM/OpenFOAM-13/etc/bashrc
#   export LIB_RGP13_SRC=<repo>/src        # fgmFluid/유틸 Make 컨벤션
#   ./build/Allwmake
#------------------------------------------------------------------------------
cd "${0%/*}" || exit 1

if [ -z "$WM_PROJECT_DIR" ]; then
    echo "Error: OpenFOAM environment not sourced." >&2
    exit 1
fi

if ! command -v nvcc &>/dev/null; then
    echo "Error: nvcc not found. Is CUDA toolkit installed?" >&2
    exit 1
fi

export CUDA_HOME=${CUDA_HOME:-/usr/local/cuda}

echo "========================================"
echo " RGP-13 thermoGPU Build"
echo "   OpenFOAM : ${WM_PROJECT_VERSION}"
echo "   CUDA     : $(nvcc --version | grep release | awk '{print $6}')"
echo "   Target   : $FOAM_USER_LIBBIN"
echo "========================================"

set -e

# CUDA 커널 라이브러리 (Foam-free)
( cd ../src/thermoGPU && wmake libso )

# CPU 대조 검증 유틸리티
( cd ../applications/utilities/Test-rgpThermoGPU && wmake )

echo ""
echo "── Build complete ──"
ls -lh "$FOAM_USER_LIBBIN/librgpThermoGPU.so" "$FOAM_USER_APPBIN/Test-rgpThermoGPU"
echo ""
echo "Verify (needs GPU; on WSL2 add --nv --bind /usr/lib/wsl):"
echo "  Test-rgpThermoGPU testCases/counterflow_fgmFluid/constant/thermo.compressibleGas4S"
