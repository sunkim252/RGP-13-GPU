#!/bin/bash
#------------------------------------------------------------------------------
# RGP-13 build script
#
# Usage (inside container):
#   cd $LIB_RGP13_SRC/../build
#   ./Allwmake
#
# 또는:
#   apptainer exec --nv openfoam13-cuda.sif bash -c \
#       "source /opt/OpenFOAM-13/etc/bashrc && cd /home/openfoam/RGP-13/build && ./Allwmake"
#------------------------------------------------------------------------------
cd "${0%/*}" || exit 1

# Verify environment
if [ -z "$WM_PROJECT_DIR" ]; then
    echo "Error: OpenFOAM environment not sourced." >&2
    echo "       Run: source /opt/OpenFOAM-13/etc/bashrc" >&2
    exit 1
fi

if ! command -v nvcc &>/dev/null; then
    echo "Error: nvcc not found. Is CUDA toolkit installed?" >&2
    exit 1
fi

export CUDA_HOME=${CUDA_HOME:-/usr/local/cuda}

echo "========================================"
echo " RGP-13 Build"
echo "   OpenFOAM : $(foamVersion 2>/dev/null || echo $WM_PROJECT_VERSION)"
echo "   CUDA     : $(nvcc --version | grep release | awk '{print $6}')"
echo "   Compiler : $WM_COMPILER"
echo "   Target   : $FOAM_USER_LIBDIR"
echo "========================================"

# Build thermoGPU library
cd ../src/thermoGPU && wmake libso 2>&1

echo ""
echo "── Build complete ──"
ls -lh $FOAM_USER_LIBDIR/librgpThermoGPU.so 2>/dev/null \
    && echo "OK: librgpThermoGPU.so" \
    || echo "FAILED: library not found"
